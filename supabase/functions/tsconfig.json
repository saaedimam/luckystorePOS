{
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": [],
    "typeRoots": ["./.types"]
  },
  "include": ["./**/*.ts", "./.types/**/*.d.ts"]
}
