# Lucky Store Monorepo Environment Template
# Copy this file to `.env` and fill in the values.
# See ENVIRONMENT.md for detailed usage instructions.

# ── 1. Core Supabase Config (Shared) ──────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# ── 2. Database Connectivity ──────────────────────────────────────────────────
# Session pooler (Transaction mode)
DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (Session mode)
DIRECT_DATABASE_URL=postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres

# ── 3. Frontend / Web App (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Edge Function URLs
VITE_IMPORT_INVENTORY_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/import-inventory
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale

# ── 4. Integrations & Third-Party APIs ────────────────────────────────────────
# SSLCommerz Payment Gateway
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false

# Google Maps & Auth
GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_O_AUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_MAPS_API_KEY_PLACES_API=your_places_api_key

# AI / Scraping
GEMINI_API_KEY=your_gemini_api_key

# ── 5. Ops & CI/CD ────────────────────────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=your_supabase_management_token
VERCEL_OIDC_TOKEN=only_needed_for_ci_cd

# ── 6. Legacy / Compatibility ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
