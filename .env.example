# Lucky Store environment contract (single source of truth)
# See ENVIRONMENT.md for detailed usage and ownership.

# 1) Required Production (mobile app startup + PIN auth flow)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# 2) Required Development (local scripts / ops tooling)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 3) Optional Integrations
# Used by payment edge functions (set in Supabase secrets for deployed functions)
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false

# Used by apps/scraper/ai-mapper.js only
GEMINI_API_KEY=your_gemini_api_key

# Legacy script compatibility (scripts/ops/create-storage-bucket.js fallback)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale

# 4) Deprecated (remove from .env if present)
# DATABASE_URL
# DIRECT_DATABASE_URL
# VITE_SUPABASE_PUBLISHABLE_KEY
# MANAGER_EMAIL
# MANAGER_PASSWORD
# CASHIER_EMAIL
# CASHIER_PASSWORD
# ADMIN_EMAIL
# ADMIN_PASSWORD
