# -----------------------------------------------------------------------------
# Lucky Store POS - Environment Template
# Copy this to .env and fill in your actual values
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Telegram Bot (optional - for notifications)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_USERS=comma,separated,usernames
TELEGRAM_HOME_CHANNEL=your-channel-id

# -----------------------------------------------------------------------------
# Hermes Gateway (optional - for AI agent access)
# -----------------------------------------------------------------------------
HERMES_GATEWAY_TOKEN=your-gateway-token-here

# -----------------------------------------------------------------------------
# Ollama (optional - for local LLM)
# -----------------------------------------------------------------------------
OLLAMA_API_KEY=ollama-local
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Vercel (optional - for deployments)
# -----------------------------------------------------------------------------
VERCEL_TOKEN=your-vercel-token-here
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_OFFLINE_MODE=true
ENABLE_LEDGER_POSTING=true
ENABLE_DAILY_RECONCILIATION=true
