# Lucky Store monorepo environment template
# Copy this file to `.env` (root) or to an app-local `.env` and replace placeholder values.
# Never commit real secrets.

# ------------------------------------------------------------------------------
# Web / frontend client (safe public keys only)
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale

# ------------------------------------------------------------------------------
# Node scripts / backend tooling (server-only secrets)
# ------------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------------------------
# Payment (SSLCommerz)
# ------------------------------------------------------------------------------
# API credentials from SSLCommerz merchant panel.
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false

# Optional overrides for Edge Functions:
# SSLCOMMERZ_SESSION_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
# SSLCOMMERZ_VALIDATOR_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
# SSLCOMMERZ_IPN_URL=https://your-project-ref.supabase.co/functions/v1/payment-ipn

# Frontend origin used by payment return handlers.
# FRONTEND_BASE_URL=http://localhost:5173
