# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale

# Node scripts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment (SSLCommerz). API store_id and store_password from the merchant panel (not the display store name).
# Edge Functions do NOT read this file: after `supabase link`, push the same keys as project secrets, e.g.
#   supabase secrets set SSLCOMMERZ_STORE_ID=... SSLCOMMERZ_STORE_PASSWORD=... SSLCOMMERZ_IS_LIVE=false \
#     FRONTEND_BASE_URL=https://your-pos-app-origin
# FRONTEND_BASE_URL is used by payment-return-* to redirect back to the Vite app (default in code: http://localhost:5173).
# Registered domain in the SSLCommerz panel must allow callback hosts (return URLs use *.supabase.co/functions/v1/...).
# Sandbox session API (v4): https://sandbox.sslcommerz.com/gwprocess/v4/api.php — https://developer.sslcommerz.com/doc/v4/
# validator: https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php (JSON, not ?wsdl)
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false
# Optional Edge secrets: SSLCOMMERZ_SESSION_API_URL, SSLCOMMERZ_VALIDATOR_URL, SSLCOMMERZ_IPN_URL (full URL; default IPN is .../functions/v1/payment-ipn)
# Local copy only (optional): the POS sends success/fail/cancel URLs to create-card-checkout in code, not via env.
