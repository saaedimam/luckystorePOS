# -----------------------------------------------------------------------------
# Lucky Store POS - Root .gitignore
# Cleaned for monorepo: Flutter + Node + Supabase + Scripts
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env*.example

apps/*/.env
apps/*/.env.*

# Secret files
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

# -----------------------------------------------------------------------------
# Node / JS / Package Managers
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

.npm/
.pnpm-store/

.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Build Outputs / Coverage / Cache
# -----------------------------------------------------------------------------
dist/
build/
out/
coverage/
.nyc_output/

.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/

*.tsbuildinfo

# -----------------------------------------------------------------------------
# Flutter / Dart
# -----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
build/

# -----------------------------------------------------------------------------
# Supabase / Local DB State
# -----------------------------------------------------------------------------
.supabase/
supabase/.temp/
supabase/.branches/
supabase/.cache/

# Dumps / backups only
dumps/
backups/
*.dump
*.sql.gz
*.sql.zip
*.bak.sql
*.sql.bak

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Editors / IDE
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json

.idea/
*.iml
*.suo
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Hosting Platforms
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]

# -----------------------------------------------------------------------------
# Temporary / Scratch
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Local AI Tool Metadata
# -----------------------------------------------------------------------------
.cursor/
.agents/
.claude/
.continue/
.trae/

# -----------------------------------------------------------------------------
# Data Exports (scoped, not global)
# -----------------------------------------------------------------------------
data/exports/
data/tmp/
apps/scraper/output/

# -----------------------------------------------------------------------------
# Archive / Legacy Local Storage
# -----------------------------------------------------------------------------
archive/
