# ------------------------------------------------------------
# Lucky Store monorepo: machine-local files and generated output
# ------------------------------------------------------------

# Environment and secrets (track only templates)
.env
.env.*
!.env.example
!.env*.example
**/.env
**/.env.*
!**/.env.example
!**/.env*.example
*.local
*.secret
*.secrets

# Certificates and private keys
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

# Dependencies
node_modules/
apps/*/node_modules/
.pnp
.pnp.js
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs and caches
apps/frontend/dist/
dist/
build/
out/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
**/.packages
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/coverage/
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/
coverage/
.nyc_output/
*.tsbuildinfo

# Runtime logs
logs/
*.log
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temp files
tmp/
temp/
*.tmp
*.bak
*.backup
*.backup.gz
*.orig
/scratch_*.js

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# Archives and backups
archive/
/supabasebackup/

# Database dumps and exports
*.dump
*.sql.gz
*.sql.zip
*.bak.sql
*.sql.bak
/dumps/
/backups/

# Generated data artifacts
/test-*.csv
/test-*.sh
/data/inventory/inventory_chunks/
/data/inventory/enrichment_report.csv
/apps/scraper/shwapno-products.xlsx
/apps/scraper/chaldal-products.xlsx
/apps/scraper/lucky-store-competitor-prices.xlsx

# Container / deployment local overrides
docker-compose.override.yml
*.override.yml
.env.docker

# Supabase local state
.supabase/
supabase/.temp/
supabase/.branches/
supabase/.cache/
supabase/.env

# Supabase migrations must always be versioned
!supabase/migrations/
!supabase/migrations/**

# Hosting local state
.vercel/

# AI / agent metadata
.cursor/
.agents/
.claude/
.continue/
.trae/
skills-lock.json

