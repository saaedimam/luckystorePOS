# -----------------------------------------------------------------------------
# Lucky Store - Repository-wide gitignore
# -----------------------------------------------------------------------------

# Environment files (local machine secrets/config only; keep examples tracked)
.env
.env.local
.env.*.local
!.env.example
!.env*.example
apps/*/.env
apps/*/.env.local

# Secrets and certificates
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*credentials*
*secrets*

# Dependency directories and package manager metadata
node_modules/
apps/*/node_modules/
.pnp
.pnp.js
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs and caches (monorepo paths kept explicit)
apps/frontend/dist/
dist/
build/
out/
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/
coverage/
.nyc_output/
*.tsbuildinfo

# Runtime and debug logs
logs/
*.log
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temporary files and local scratch artifacts
tmp/
temp/
*.tmp
*.bak
*.backup
*.backup.gz
*.orig
/scratch_*.js

# Editor and IDE artifacts
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# OS metadata
.DS_Store
**/.DS_Store
Thumbs.db

# Local archives and one-off backup directories
archive/
/supabasebackup/

# Database dumps and local exports (do not ignore *.sql globally)
*.dump
*.sql.gz
*.sql.zip
*.bak.sql
*.sql.bak
/dumps/
/backups/

# Generated data artifacts only (keep canonical/source datasets trackable)
/test-*.csv
/test-*.sh
/data/inventory/inventory_chunks/
/data/inventory/enrichment_report.csv
/apps/scraper/shwapno-products.xlsx
/apps/scraper/chaldal-products.xlsx
/apps/scraper/lucky-store-competitor-prices.xlsx

# Docker / local overrides (machine-specific)
docker-compose.override.yml
*.override.yml
.env.docker

# Supabase and local DB tooling
.supabase/
supabase/.temp/

# Hosting platform local state
.vercel/

# AI/IDE local metadata
.cursor/
.agents/
.claude/
.continue/
.trae/
skills-lock.json

# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
