# -----------------------------------------------------------------------------
# Lucky Store POS - Root .gitignore
# Cleaned for monorepo: Flutter + Node + Supabase + Scripts
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env*.example

apps/*/.env
apps/*/.env.*

# Secret files
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

# -----------------------------------------------------------------------------
# Node / JS / Package Managers
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

.npm/
.pnpm-store/

.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Build Outputs / Coverage / Cache
# -----------------------------------------------------------------------------
dist/
build/
out/
coverage/
.nyc_output/

.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/

*.tsbuildinfo

# -----------------------------------------------------------------------------
# Flutter / Dart
# -----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
pubspec.lock
build/

# -----------------------------------------------------------------------------
# Supabase / Local DB State
# -----------------------------------------------------------------------------
.supabase/
supabase/.temp/
supabase/.branches/
supabase/.cache/
deno.lock

# Dumps / backups only
dumps/
backups/
*.dump
*.sql.gz
*.sql.zip
*.bak.sql
*.sql.bak
supabasebakcup/
*.backup

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Editors / IDE
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json

.idea/
*.iml
*.suo
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Hosting Platforms
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]

# -----------------------------------------------------------------------------
# Temporary / Scratch
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
.~*
*~

# -----------------------------------------------------------------------------
# Local AI Tool Metadata
# -----------------------------------------------------------------------------
.cursor/
.agents/
.claude/
.continue/
.trae/
skills-lock.json

# -----------------------------------------------------------------------------
# Data Exports (scoped, not global)
# -----------------------------------------------------------------------------
data/exports/
data/tmp/
apps/scraper/output/

# Scraper data files (keep code, ignore data)
apps/scraper/*_products.json
apps/scraper/scraped_images/
*.xlsx
*.xls
*.csv
!data/samples/*.csv

# -----------------------------------------------------------------------------
# Archive / Legacy Local Storage
# -----------------------------------------------------------------------------
archive/

# -----------------------------------------------------------------------------
# IDE Inspection Artifacts (IntelliJ / Android Studio)
# -----------------------------------------------------------------------------
# These large XML files are auto-generated and should not be versioned.
SpellCheckingInspection.xml
AndroidDomInspection.xml
*.inspectionProfile.xml
.inspections/

# -----------------------------------------------------------------------------
# Scratch / One-off SQL files
# -----------------------------------------------------------------------------
scratch_*.sql
apply_*_v2.sql

# -----------------------------------------------------------------------------
# Flutter asset env (safe to bundle, but keep out of git history)
# -----------------------------------------------------------------------------
# app.env is safe-to-bundle (anon key only) but still shouldn't be committed
# to avoid leaking even non-secret config. Manage via CI secrets.
apps/mobile_app/assets/app.env
apps/mobile_app/flutter
