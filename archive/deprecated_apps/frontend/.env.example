VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: used by src/lib/supabase/client.ts (shadcn Supabase SSR client) if set instead of anon JWT flows.
# VITE_SUPABASE_PUBLISHABLE_KEY=...
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=...

# Optional: explicit sale edge function URL. If omitted, frontend falls back
# to VITE_PROCESS_SALE_EDGE_URL.
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale

# Optional fallback if create-sale URL is not configured.
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale

# Optional: Google Maps Platform API key (Places autocomplete, Address Validation, Maps JS).
# Prefer this name (Places REST + Maps JS). VITE_ prefix is required for Vite to expose it.
# Enable: Places API (New), Address Validation API, and any Maps JS libraries you use.
# Restrict this key by HTTP referrer in Google Cloud Console.
# Example referrer patterns:
#   http://localhost:5173/*
#   https://your-domain.com/*
VITE_GOOGLE_MAPS_API_KEY_PLACES_API=your_google_maps_places_api_key
# Legacy fallback if the variable above is unset:
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
