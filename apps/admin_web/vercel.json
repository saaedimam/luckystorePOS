{
    "rewrites": [
          {
                  "source": "/admin/assets/(.*)",
                  "destination": "/assets/$1"
          },
          {
                  "source": "/admin/sw.js",
                  "destination": "/sw.js"
          },
          {
                  "source": "/admin/manifest.json",
                  "destination": "/manifest.json"
          },
          {
                  "source": "/admin",
                  "destination": "/index.html"
          },
          {
                  "source": "/admin/(.*)",
                  "destination": "/index.html"
          }
    ]
}
