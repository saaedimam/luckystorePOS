{
  "cleanUrls": true,
    "rewrites": [
          {
                  "source": "/admin",
                  "destination": "/index.html"
          },
          {
                  "source": "/admin/assets/(.*)",
                  "destination": "/assets/$1"
          },
          {
                  "source": "/admin/(.*)",
                  "destination": "/index.html"
          }
    ]
}
