# -----------------------------------------------------------------------------
# Frontend (Vite/React) gitignore
# -----------------------------------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Build artifacts and caches
dist/
dist-ssr/
build/
out/
coverage/
.nyc_output/
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo

# Environment (explicit + wildcard; no *.env)
.env
.env.local
.env.development
.env.production
.env.test
.env.*
!.env.example
!.env*.example
*.local

# Logs
logs/
*.log
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temp files
tmp/
temp/
*.tmp
*.bak
*.orig

# Editor (only extensions.json un-ignored)
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db
